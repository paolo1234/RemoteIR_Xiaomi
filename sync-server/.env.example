# IRXiaomi Sync Server - Configurazione
# Copia questo file in .env e modifica i valori

# Database PostgreSQL
DATABASE_URL=postgresql://irxiaomi:irxiaomi_pass@localhost:5432/irxiaomi

# Server
HOST=0.0.0.0
PORT=8000

# Sincronizzazione
SYNC_INTERVAL_MINUTES=60
MAX_BATCH_SIZE=500

# Rate limiting (richieste/minuto per IP)
API_RATE_LIMIT=100

# Supabase / Storage (opzionale)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-supabase-key

# JWT Secret per autenticazione (opzionale)
# JWT_SECRET=your-jwt-secret-here
# JWT_ALGORITHM=HS256
